# Copy this file to .env and fill in your values.
# Never commit .env to git.

# eBay Developer credentials — developer.ebay.com
# Production keys (not sandbox) — needed for real listings
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Anthropic API — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# AWS Lambda — S3 bucket for persisting the SQLite database between invocations.
# Leave blank for local runs; required when deploying to Lambda.
S3_BUCKET=your-bucket-name
S3_DB_KEY=warhammer-scout/prices.db

# Telegram bot 1 — Warhammer bargain alerts (daily buys)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your-chat-id

# Telegram bot 2 — market research digest (weekly)
TELEGRAM_DIGEST_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_DIGEST_CHAT_ID=your-chat-id

# Telegram bot 3 — fantasy & sci-fi bargain alerts
TELEGRAM_FANTASY_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_FANTASY_CHAT_ID=your-chat-id

# Etsy API — etsy.com/developers (optional — source skips silently if unset)
ETSY_API_KEY=your-etsy-api-keystring
